# Copy per app. Same Supabase project, different env var naming.

# apps/extension/.env  (WXT exposes WXT_* on import.meta.env)
WXT_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
WXT_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# apps/web/.env.local  (Next.js exposes NEXT_PUBLIC_* to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
