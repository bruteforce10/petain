# Supabase project credentials (Settings → API). Same project as apps/extension.
WXT_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
WXT_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Base URL of the web dashboard (apps/web) the popup's "Lihat Tabel Data" button
# opens after a scrape. Falls back to http://localhost:3000 if unset.
WXT_WEB_URL=http://localhost:3000
