NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Google AI Studio (Gemini) — free key from https://aistudio.google.com/apikey
# Server-side only (no NEXT_PUBLIC_ prefix) so it never reaches the browser.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Optional: override the model. Defaults to gemini-2.5-flash (free tier).
# GEMINI_MODEL=gemini-2.5-flash
