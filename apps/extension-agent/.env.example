# Supabase project credentials (Settings → API). Same project as apps/extension.
WXT_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
WXT_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: bake an Anthropic API key at build time. Leaving this blank means
# the user must paste their own key into the popup; it's stored only in
# chrome.storage.local. Storing an API key in any client artifact is unsafe —
# use only for personal experimentation.
WXT_ANTHROPIC_API_KEY=
