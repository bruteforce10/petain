{
  "name": "petain",
  "private": true,
  "version": "0.1.0",
  "description": "Petain monorepo: scraper extension + web dashboard",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:ext": "turbo run dev --filter=@petain/extension",
    "dev:web": "turbo run dev --filter=@petain/web",
    "dev:labs": "turbo run dev --filter=@petain/labs",
    "dev:ext-class": "turbo run dev --filter=@petain/extension-classic",
    "build": "turbo run build",
    "compile": "turbo run compile",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.5.3"
  }
}
